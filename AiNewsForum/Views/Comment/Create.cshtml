@model AiNewsForum.Models.Comment

@{
    ViewData["Title"] = "Add a Comment";
}

<h1 class="text-primary fw-bold">Add a Comment</h1>
<hr class="mb-4" />

<form asp-action="Create" method="post" class="p-4 border rounded shadow bg-light">
    <input type="hidden" asp-for="DiscussionId" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label fw-bold">Your Comment</label>
        <textarea asp-for="Content" class="form-control shadow-sm" rows="4" required></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="d-flex gap-3">
        <button type="submit" class="btn btn-success btn-lg">Submit Comment</button>
        <a asp-controller="Home" asp-action="getDiscussion" asp-route-id="@Model.DiscussionId" class="btn btn-secondary btn-lg">Back to Discussion</a>
    </div>
</form>
